{
  "version": 2,
  "rewrites": [
    { "source": "/api/stkpush",  "destination": "/stkpush.js"  },
    { "source": "/api/stkquery", "destination": "/stkquery.js"  },
    { "source": "/api/callback", "destination": "/callback.js"  },
    { "source": "/api/register", "destination": "/register.js"  },
    { "source": "/api/login",    "destination": "/login.js"     },
    { "source": "/api/me",       "destination": "/me.js"        },
    { "source": "/(.*)",         "destination": "/index.html"   }
  ]
}
